# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# JWT (RS256 - generate with: make keys)
JWT_PRIVATE_KEY_PATH=./private.pem
JWT_PUBLIC_KEY_PATH=./public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (port 5433 to avoid conflict with other local Postgres)
DATABASE_URL=postgresql://citizen_alert:password@localhost:5433/citizen_alert_db

# Redis (port 6380 to avoid conflict with other local Redis)
REDIS_URL=redis://localhost:6380/0

# AWS S3 / MinIO
STORAGE_BACKEND=minio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=citizen-alert
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_REGION=us-east-1

# Firebase (push notifications) - leave empty in dev
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# SMS - Twilio (leave empty in dev, OTP printed in response)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email - SendGrid (leave empty in dev)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@citizenalert.tn

# AI microservice
AI_SERVICE_URL=http://localhost:8001

# Sentry (leave empty in dev)
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
USER_RATE_LIMIT_PER_MINUTE=20
